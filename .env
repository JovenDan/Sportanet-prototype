# Variables de entorno para el proyecto Sportanet

# ===== BACKEND =====

# Puerto del servidor
PORT=5000

# Base de datos
DB_HOST=localhost
DB_PORT=5000
DB_USER=root
DB_PASSWORD=password
DB_NAME=sportanet_v1

# JWT
JWT_SECRET=tu-clave-secreta-super-larga-y-segura-aqui-min-32-caracteres
JWT_EXPIRE=24h

# CORS
CORS_ORIGIN=http://localhost:5000

# Node
NODE_ENV=development

# ===== FRONTEND =====

# URL del API backend
VITE_API_URL=http://localhost:5000

# Ambiente
VITE_ENV=development
